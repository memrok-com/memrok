{
  "name": "memrok",
  "version": "0.3.3",
  "type": "module",
  "description": "Memory with judgment. Persistent, structured, intelligent memory layer for OpenClaw AI agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "@memrok/daemon": "0.3.3",
    "@memrok/injector": "0.3.3",
    "@memrok/scribe": "0.3.3",
    "@memrok/store": "0.3.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "openclaw",
    "memrok",
    "memory",
    "ai-agent",
    "context-engine",
    "knowledge-graph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memrok-com/memrok.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
