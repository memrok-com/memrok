{
  "id": "memrok",
  "kind": "context-engine",
  "name": "Memrok Memory Layer",
  "description": "Memory with judgment. Persistent, structured, intelligent memory layer for OpenClaw AI agents.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": { "type": "string" },
      "scribeProvider": { "type": "string" },
      "scribeModel": { "type": "string" },
      "reflection": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "deltaPasses": { "type": "number" },
          "cooldownHours": { "type": "number" },
          "provider": { "type": "string" },
          "model": { "type": "string" }
        }
      },
      "watchPaths": {
        "type": "array",
        "items": { "type": "string" }
      },
      "deltaThreshold": { "type": "number" },
      "idleMinutes": { "type": "number" },
      "tokenBudget": { "type": "number" }
    }
  }
}
